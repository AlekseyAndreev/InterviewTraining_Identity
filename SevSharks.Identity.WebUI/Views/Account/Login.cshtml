@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration

@model LoginViewModel

@section CustomStyles {
   <style>
        .social-list__item-btn-VK {
            width: 33px;
            height: 33px;
            background-image: url("../img/icons/icon-vk.svg");
            background-repeat: no-repeat;
            background-size: cover;
            background-position: center center;
            border: none;
        }

        .social-list__item-btn-Microsoft {
            width: 133px;
            height: 33px;
            background-image: url("../img/icons/icon-microsoft.png");
            background-size: cover;
            background-repeat: no-repeat;
            background-position: center center;
            border: none;
        }

        .social-list__item-btn-Google {
            width: 33px;
            height: 33px;
            background-image: url("../img/icons/icon-google.svg");
            background-repeat: no-repeat;
            background-size: cover;
            background-position: center center;
            border: none;
        }

        /* Alert styles - переопределяем для гарантированного отображения */
        .alert-box {
            padding: 15px 20px;
            margin-bottom: 20px;
            border: 1px solid transparent;
            border-radius: 4px;
            background-color: #d9edf7;
            border-color: #17a2b8;
            color: #0c5460;
        }
        .alert-box.alert-success {
            background-color: #d4edda;
            border-color: #28a745;
            color: #155724;
        }
        .alert-box.alert-danger {
            background-color: #f8d7da;
            border-color: #dc3545;
            color: #721c24;
        }

        .alert-box .close-btn {
            float: right;
            font-size: 21px;
            font-weight: 700;
            line-height: 1;
            color: #000;
            text-shadow: 0 1px 0 #fff;
            opacity: .5;
            background: none;
            border: none;
            cursor: pointer;
            padding: 0;
        }
        .alert-box .close-btn:hover {
            opacity: .75;
        }
   </style>
}

<div class="login-page">
   <div>
       <h3><a href="@Configuration["MainUrl"]">Назад в основой сайт</a></h3>
   </div>
   <div>
       <h1>Вход в приложение</h1>
   </div>

    @if (TempData["EmailConfirmationMessage"] != null)
    {
       <div class="alert-box alert-success" role="alert">
            @TempData["EmailConfirmationMessage"]
           <button type="button" class="close-btn" data-dismiss="alert" aria-label="Закрыть">
               <span aria-hidden="true">&times;</span>
           </button>
       </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
       <div class="alert-box alert-danger" role="alert">
            @TempData["ErrorMessage"]
           <button type="button" class="close-btn" data-dismiss="alert" aria-label="Закрыть">
               <span aria-hidden="true">&times;</span>
           </button>
       </div>
    }

   <partial name="_ValidationSummary" />

   <div class="row">

        @if (Model.EnableLocalLogin)
        {
           <div class="col-sm-3" style="width: 300px;">
               <div class="panel panel-default">
                   <div class="panel-heading">
                       <h3 class="panel-title">Войти</h3>
                   </div>
                   <div class="panel-body">
                       <form asp-route="Login">
                           <input type="hidden" asp-for="ReturnUrl" />

                           <fieldset>
                               <div class="form-group">
                                   <label asp-for="Login"></label>
                                   <input class="form-control" placeholder="Пользователь" asp-for="Login" autofocus>
                               </div>
                               <div class="form-group">
                                   <label asp-for="Password"></label>
                                   <input type="password" class="form-control" placeholder="Пароль" asp-for="Password" autocomplete="off">
                               </div>
                                @if (Model.AllowRememberLogin)
                                {
                                   <div class="form-group login-remember">
                                       <label asp-for="RememberLogin">
                                           <input asp-for="RememberLogin">
                                           <strong>Запомнить мой пароль</strong>
                                       </label>
                                   </div>
                                }
                               <div class="form-group">
                                   <button class="btn btn-primary" name="button" value="login">Войти</button>
                                   <a class="btn btn-primary" asp-action="Register" asp-controller="Account" asp-route-returnUrl="@Model.ReturnUrl" style="margin-top: 15px;">На страницу регистрации</a>
                                   <a class="btn btn-primary" href="@Configuration["MainUrl"]" style="margin-top: 15px;">Назад в основой сайт</a>
                               </div>
                           </fieldset>
                       </form>
                   </div>
               </div>
           </div>
        }
        @if (Model.VisibleExternalProviders.Any() && false)
        {
           <div class="col-sm-2 external-providers" style="width: 300px;">
               <div class="panel panel-default">
                   <div class="panel-heading">
                       <h3 class="panel-title">Войти через:</h3>
                   </div>
                   <div class="panel-body">
                       <ul class="list-inline">
                            @foreach (var provider in Model.VisibleExternalProviders)
                            {
                               <li>
                                   <form asp-action="ExternalLogin" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">
                                       <button class="social-list__item social-list__item-btn-@provider.Name"
                                                type="submit"
                                                name="provider"
                                                value="@provider.DisplayName">
                                       </button>
                                   </form>
                               </li>
                            }
                       </ul>
                   </div>
               </div>
           </div>
        }

        @if (!Model.EnableLocalLogin && !Model.VisibleExternalProviders.Any())
        {
           <div class="alert alert-warning">
               <strong>Invalid login request</strong>
                There are no login schemes configured for this client.
           </div>
        }
   </div>
</div>
